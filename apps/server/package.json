{
  "name": "@texas-poker/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/index.js",
    "db:push": "prisma db push --skip-generate",
    "start:prod": "prisma db push --skip-generate && node dist/index.js",
    "test": "vitest run",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@prisma/client": "^6.10.1",
    "@texas-poker/poker-engine": "workspace:*",
    "@texas-poker/shared": "workspace:*",
    "fastify": "^5.4.0",
    "ioredis": "^5.7.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "prisma": "^6.10.1",
    "socket.io-client": "^4.8.1"
  }
}
